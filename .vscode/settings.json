{
  "[jinja-html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[sql]": {
    "editor.defaultFormatter": "ReneSaarsoo.sql-formatter-vsc"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "autoDocstring.docstringFormat": "sphinx-notypes",
  "cmake.sourceDirectory": "${workspaceFolder}/speedup",
  "coverage-gutters.ignoredPathGlobs": "**/{node_modules,.venv,data}/**",
  "css.styleSheets": [
    "node_modules/bootstrap-icons/font/bootstrap-icons.css",
    "app/static/vite/assets/bootstrap.*.css",
    "app/views/**/*.scss"
  ],
  "editor.formatOnSaveMode": "file",
  "editor.rulers": [88],
  "editor.unicodeHighlight.allowedCharacters": {
    "‐": true,
    "›": true,
    "»": true,
    "′": true,
    "×": true,
    "➕": true,
    "𝕏": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    ".gitignore": ".gitattributes",
    "*.html.jinja": "${capture}.*",
    "*.ts": "${capture}.macro.ts,${capture}.scss",
    "*.tsx": "${capture}.macro.ts,${capture}.scss",
    "package.json": ".npmrc,bunfig.toml,bun.lock",
    "pyproject.toml": "uv.lock",
    "README.md": "LICENSE"
  },
  "files.exclude": {
    ".*cache/": true,
    ".buf-deps/": true,
    ".ck/": true,
    ".direnv/": true,
    ".venv/": true,
    "{app,script}/**/*.c": true,
    "**/__pycache__/": true,
    "**/_generated/": true,
    "**/*.egg-info/": true,
    "**/*.html": true,
    "**/*.so": true,
    "**/build/": true,
    "/nix/store/": true,
    "app/static/vite/**/*.js": true,
    "config/locale/download/": true,
    "dist/": true,
    "speedup/target": true
  },
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsserver.automaticTypeAcquisition.enabled": true,
  "prettier.documentSelectors": ["**/*.html.jinja"],
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.packageIndexDepths": [
    {
      "depth": 3,
      "includeAllSymbols": false,
      "name": ""
    }
  ],
  "python.experiments.enabled": false,
  "python.terminal.activateEnvironment": false,
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "scss.lint.vendorPrefix": "ignore",
  "somesass.workspace.loadPaths": ["app/views"]
}
