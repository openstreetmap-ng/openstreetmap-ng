{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleDetection": "force",
    "allowJs": true,

    "jsx": "react-jsx",
    "jsxImportSource": "preact",

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "useUnknownInCatchVariables": false,

    "paths": {
      "@components/*": ["./app/views/components/*"],
      "@utils/*": ["./app/views/utils/*"],
      "@runtime/*": ["./app/views/runtime/*"],
      "@styles/*": ["./app/views/styles/*"],
      "@proto/*": ["./app/views/proto/*"],
      "@map/*": ["./app/views/map/*"],
      "@data/*": ["./app/views/data/*"],
      "@index/*": ["./app/views/index/*"]
    },
    "types": [
      "@types/bootstrap",
      "@types/bun",
      "@types/geojson",
      "typed-query-selector/strict"
    ]
  },
  "exclude": ["app/views/proto/**/*", "app/views/data/**/*"],
  "include": [
    "app/views/**/*.ts",
    "app/views/**/*.tsx",
    "vite.config.ts",
    "typings/**/*.d.ts"
  ]
}
